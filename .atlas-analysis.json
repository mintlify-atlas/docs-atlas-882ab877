  "keyFeatures": [
    "YouTube transcript extraction with multi-language support",
    "Video metadata retrieval (title, description, views, likes, chapters, related videos)",
    "Paginated YouTube comments with sort-by-newest or top support",
    "Credit-based usage billing with atomic deductions",
    "Redis (Upstash) caching for transcripts, details, and comments",
    "PostgreSQL persistence via Drizzle ORM with Neon serverless",
    "API key authentication via x-api-key or api-x-key headers",
    "Activity logging for every request"
  ],
  "publicApiSurface": [
    "POST /v1/video/transcript",
    "POST /v1/video/details",
    "POST /v1/video/comments",
    "GET /health"
  ]
}
